# Clave de la API de Google Gemini (nivel gratuito). Necesaria para el análisis
# de imagen y para la búsqueda de alimentos con IA + PubMed. Vive solo en el servidor.
# Consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcional: modelo de Gemini a usar (por defecto gemini-2.5-flash, con nivel gratuito).
GEMINI_MODEL=gemini-2.5-flash

# Opcionales, para consultar PubMed con más cuota y sin límites de cortesía
# (ver https://www.ncbi.nlm.nih.gov/account/settings/ para obtener una api_key).
NCBI_API_KEY=
NCBI_EMAIL=
