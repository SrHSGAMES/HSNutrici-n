# Clave de la API de Anthropic (Claude). Necesaria para el análisis de imagen
# y para la búsqueda de alimentos con IA + PubMed. Vive solo en el servidor.
ANTHROPIC_API_KEY=sk-ant-...

# Opcionales, para consultar PubMed con más cuota y sin límites de cortesía
# (ver https://www.ncbi.nlm.nih.gov/account/settings/ para obtener una api_key).
NCBI_API_KEY=
NCBI_EMAIL=
